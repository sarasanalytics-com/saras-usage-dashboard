PORT=8080

# Get from Azure Portal > App registrations > Your app > Application (client) ID
MICROSOFT_CLIENT_ID=your-client-id-here

# Your Azure AD tenant ID (or 'common' for multi-tenant)
# Found at Azure Portal > App registrations > Your app > Directory (tenant) ID
TENANT_ID=your-tenant-id-or-common

# Comma-separated list of allowed origins (where dashboard is hosted)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Only allow users with this domain
ALLOWED_DOMAIN=@sarasanalytics.com
