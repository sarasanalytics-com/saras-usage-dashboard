name: Update Dashboard

on:
  schedule:
    # Run daily at 7:00 AM IST (1:30 AM UTC)
    - cron: '30 1 * * *'
  workflow_dispatch:

jobs:
  update:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: |
          pip install -r requirements.txt

      # ── OAuth Credentials Injection ──
      - name: Update Dashboard with Microsoft OAuth
        env:
          # Get these from GitHub Settings > Secrets > Repository secrets
          MICROSOFT_CLIENT_ID: ${{ secrets.MICROSOFT_CLIENT_ID }}
          BACKEND_URL: ${{ secrets.BACKEND_URL }}

          # API keys for data collection
          ANTHROPIC_ANALYTICS_KEY: ${{ secrets.ANTHROPIC_ANALYTICS_KEY }}
          ANTHROPIC_COMPLIANCE_KEY: ${{ secrets.ANTHROPIC_COMPLIANCE_KEY }}
          CLICKUP_API_KEY: ${{ secrets.CLICKUP_API_KEY }}

        run: |
          python scripts/update_dashboard.py

      - name: Commit and push changes
        uses: stefanzweifel/git-auto-commit-action@v5
        with:
          commit_message: '[skip ci] Daily dashboard update - OAuth ready'
          file_pattern: 'index.html data/*.json'
          push_options: '--force'

# ── Setup Instructions ──
#
# 1. Store OAuth credentials as GitHub Secrets:
#    - MICROSOFT_CLIENT_ID: Your Application (client) ID from Azure Portal
#    - BACKEND_URL: Your Cloud Run service URL
#
# 2. Store API credentials as GitHub Secrets:
#    - ANTHROPIC_ANALYTICS_KEY: From Claude Admin
#    - ANTHROPIC_COMPLIANCE_KEY: For compliance reporting
#    - CLICKUP_API_KEY: From ClickUp workspace settings
#
# 3. Save this file to: .github/workflows/update-dashboard.yml
#
# 4. The workflow will:
#    - Run daily at 7:00 AM IST (or on manual trigger)
#    - Inject OAuth credentials into index.html
#    - Collect fresh data from all sources
#    - Commit and push updated dashboard
#
# Note: The GOOGLE_CLIENT_ID and BACKEND_URL will be automatically
#       injected by update_dashboard.py using environment variables.
